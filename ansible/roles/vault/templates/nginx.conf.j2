events {}

http {
    server {
        listen 443 ssl;
        server_name {{ vault_nginx_vhost_name }};

        ssl_certificate /etc/nginx/certs/{{ vault_nginx_vhost_name }}.crt;
        ssl_certificate_key /etc/nginx/certs/{{ vault_nginx_vhost_name }}.key;
        ssl_protocols TLSv1.2 TLSv1.3;
        ssl_ciphers HIGH:!aNULL:!MD5;

        location / {
            proxy_pass https://{{ vault_nginx_vhost_name }}:8200;
            proxy_ssl_verify off;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        }
    }
}
